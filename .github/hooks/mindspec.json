{
  "hooks": {
    "preToolUse": [
      {
        "bash": "mindspec hook worktree-file --format copilot",
        "timeoutSec": 5,
        "type": "command"
      },
      {
        "bash": "mindspec hook worktree-bash --format copilot",
        "timeoutSec": 5,
        "type": "command"
      },
      {
        "bash": "mindspec hook needs-clear --format copilot",
        "timeoutSec": 5,
        "type": "command"
      },
      {
        "bash": "mindspec hook workflow-guard --format copilot",
        "timeoutSec": 5,
        "type": "command"
      }
    ],
    "sessionStart": [
      {
        "bash": "source=$(cat | jq -r '.source // \"unknown\"'); mindspec state write-session --source=\"$source\" 2\u003e/dev/null; mindspec instruct 2\u003e/dev/null || echo 'mindspec instruct unavailable — run make build'",
        "timeoutSec": 10,
        "type": "command"
      }
    ]
  },
  "version": 1
}
