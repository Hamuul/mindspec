# MindSpec local runtime files (ADR-0015) — not version-controlled.
# Mode and state are derived from molecules; these are transient caches.
.mindspec/session.json
.mindspec/mode-cache
.mindspec/current-spec.json

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Worktrees
worktree-*/

# Go
bin/
/mindspec
*.exe

# OS
.DS_Store
Thumbs.db

# beads git submodule
beads/
# mindspec worktrees
.worktrees/
.worktrees/worktree-mindspec-u7mk/
worktree-mindspec-u7mk/
