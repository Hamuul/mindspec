# Mindspec local state (not version-controlled)
.mindspec/

# Beads runtime artifacts are handled by .beads/.gitignore
# This rule catches any stray runtime files outside .beads/
**/bd.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Go
bin/
*.exe

# OS
.DS_Store
Thumbs.db
